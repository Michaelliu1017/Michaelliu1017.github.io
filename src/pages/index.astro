---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import BrandLogo from '../components/BrandLogo.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import profilePhoto from '../assets/profile-photo.png';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 4);

const allExperience = await getCollection('experience');
const experience = allExperience.sort((a, b) => a.data.order - b.data.order);

const skills = [
  { category: 'Languages',    i18nKey: 'skill.languages', items: ['Java', 'Python', 'C/C++', 'SQL', 'Golang', 'JavaScript', 'HTML/CSS', 'Racket'], color: 'rose' },
  { category: 'ML / AI',      i18nKey: 'skill.mlai',      items: ['PyTorch', 'Spring AI', 'RAG', 'OpenCV', 'DINOv2', 'Ollama', 'NumPy', 'scikit-learn'], color: 'gold' },
  { category: 'Systems & GPU',i18nKey: 'skill.systems',   items: ['CUDA', 'POSIX Threads', 'MPI', 'CSR Sparse', 'Memory Optimization', 'Concurrency'], color: 'violet' },
  { category: 'Frameworks',   i18nKey: 'skill.frameworks', items: ['Spring Boot', 'Flask', 'React', 'Node.js', 'Express', 'REST APIs'], color: 'rose' },
  { category: 'Data & Storage',i18nKey: 'skill.data',     items: ['PostgreSQL', 'MongoDB', 'MySQL', 'Redis', 'pgvector', 'Milvus'], color: 'gold' },
  { category: 'DevOps & Cloud',i18nKey: 'skill.devops',   items: ['Docker', 'Kubernetes', 'AWS', 'GitLab CI', 'GitHub Actions', 'WebSocket'], color: 'violet' },
];

const stats = [
  { value: 'NYU',   label: 'Courant M.S. CS',       i18n: 'stats.nyu'      },
  { value: '5+',    label: 'Projects Shipped',        i18n: 'stats.projects' },
  { value: '121×',  label: 'GPU Speedup Achieved',    i18n: 'stats.gpu'      },
  { value: 'AI',    label: 'Concentration',            i18n: 'stats.ai'       },
];

const affiliations = [
  { brand: 'nyu',          label: 'NYU Courant'  },
  { brand: 'fourparadigm', label: '4Paradigm'    },
  { brand: 'cas',          label: 'CASIA'        },
  { brand: 'github',       label: 'GitHub'       },
  { brand: 'pytorch',      label: 'PyTorch'      },
  { brand: 'spring',       label: 'Spring Boot'  },
  { brand: 'langchain',    label: 'LangChain'    },
  { brand: 'flask',        label: 'Flask'        },
];
---

<Layout title="Guoliang Liu — CS Graduate & Software Engineer">
  <Navigation />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0 grid-bg opacity-40"></div>
      <div class="absolute top-1/4 -left-32 w-96 h-96 bg-neon-rose/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-neon-gold/5 rounded-full blur-3xl"></div>

      <div class="section-container relative z-10 text-center py-20">
        <div class="flex flex-col md:flex-row md:items-center md:justify-center md:gap-10 mb-6">
          <div class="animate-fade-in md:order-2 flex-shrink-0 mb-6 md:mb-0">
            <div class="w-36 h-36 md:w-44 md:h-44 rounded-2xl border-2 border-neon-rose/30 shadow-[0_0_20px_rgba(232,98,26,0.18)] mx-auto bg-surface overflow-hidden">
              <img
                src={profilePhoto.src}
                alt="Guoliang Liu"
                width={profilePhoto.width}
                height={profilePhoto.height}
                class="h-full w-full object-cover object-center"
                loading="eager"
                decoding="async"
              />
            </div>
          </div>
          <div class="animate-fade-in md:text-left">
            <p class="text-neon-rose font-mono text-sm tracking-widest uppercase mb-6" data-i18n="hero.subtitle">
              Software Engineer &middot; CS Graduate Student
            </p>
            <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-heading font-bold leading-tight">
              <span class="block text-gradient-neon">Guoliang</span>
              <span class="flex items-end gap-4">
                <span class="text-text-bright">Liu</span>
                <span class="text-text-bright/70 text-4xl sm:text-5xl md:text-6xl lg:text-7xl tracking-wide leading-none mb-3" data-en="" data-zh="刘国梁"></span>
              </span>
            </h1>
          </div>
        </div>
        
        <p class="text-lg md:text-xl text-muted-light max-w-2xl mx-auto mb-10 leading-relaxed" data-i18n="hero.desc">
          Building AI/ML systems, GPU-accelerated computing, and full-stack platforms.
          M.S. CS student at NYU Courant with a focus on AI and systems programming.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/projects" class="btn-neon-fill">
            <span data-i18n="hero.cta.projects">View Projects</span>
            <svg class="inline-block w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href="/contact" class="btn-neon" data-i18n="hero.cta.contact">Get in Touch</a>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="relative py-12 border-y border-white/5">
      <div class="section-container">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {stats.map((stat, i) => (
            <div class={`reveal reveal-delay-${i + 1} text-center`}>
              <div class="text-3xl md:text-4xl font-heading font-bold text-gradient-rose mb-1">{stat.value}</div>
              <div class="text-sm text-muted" data-i18n={stat.i18n}>{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tech Stack Strip -->
    <section class="py-10 border-b border-white/5">
      <div class="section-container">
        <p class="reveal text-center text-[10px] text-muted uppercase tracking-[0.2em] mb-6" data-i18n="section.tech">
          Tech Stack & Affiliations
        </p>
        <div class="brand-strip">
          {affiliations.map((item, i) => (
            <div class={`brand-strip-item reveal reveal-delay-${(i % 5) + 1}`}>
              <BrandLogo brand={item.brand} size="md" />
              <span class="text-[10px] text-muted/70">{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Featured Projects -->
    <section class="py-20 md:py-28">
      <div class="section-container">
        <div class="reveal text-center mb-14">
          <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">
            <span data-i18n="section.featured.t1">Featured</span>
            <span class="text-gradient-rose"> <span data-i18n="section.featured.t2">Projects</span></span>
          </h2>
          <p class="text-muted max-w-lg mx-auto" data-i18n="section.featured.desc">
            AI/ML systems, GPU computing, and full-stack applications — each with a detailed write-up.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {featuredProjects.map((project, i) => (
            <ProjectCard project={project} maxTags={4} revealClass={`reveal reveal-delay-${i + 1}`} />
          ))}
        </div>

        <div class="reveal text-center mt-10">
          <a href="/projects" class="btn-neon text-sm">
            <span data-i18n="section.featured.cta">View All Projects</span>
            <svg class="inline-block w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>
    </section>

    <div class="divider-neon-animated"></div>

    <!-- Skills Section -->
    <section class="py-20 md:py-28">
      <div class="section-container">
        <div class="reveal text-center mb-14">
          <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">
            <span data-i18n="section.skills.t1">Skills &</span>
            <span class="text-gradient-rose"> <span data-i18n="section.skills.t2">Technologies</span></span>
          </h2>
          <p class="text-muted max-w-lg mx-auto" data-i18n="section.skills.desc">
            Full-stack proficiency across AI/ML, systems programming, GPU computing, and cloud infrastructure.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {skills.map((group, i) => (
            <div class={`reveal reveal-delay-${(i % 5) + 1} card-neon`}>
              <h3 data-i18n={group.i18nKey} class={`text-sm font-heading font-semibold uppercase tracking-wider mb-3 ${
                group.color === 'rose' ? 'text-neon-rose' : group.color === 'gold' ? 'text-neon-gold' : 'text-neon-violet'
              }`}>
                {group.category}
              </h3>
              <div class="flex flex-wrap gap-2">
                {group.items.map(item => (
                  <span class={`text-xs px-2.5 py-1 rounded-full border ${
                    group.color === 'rose' ? 'bg-neon-rose/5 text-neon-rose/80 border-neon-rose/15' :
                    group.color === 'gold' ? 'bg-neon-gold/5 text-neon-gold/80 border-neon-gold/15' :
                    'bg-neon-violet/5 text-neon-violet/80 border-neon-violet/15'
                  }`}>{item}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="divider-neon-animated"></div>

    <!-- Experience Timeline -->
    <section class="py-20 md:py-28">
      <div class="section-container">
        <div class="reveal text-center mb-14">
          <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">
            <span data-i18n="section.exp.t1">Experience</span>
            <span class="text-gradient-rose"> <span data-i18n="section.exp.t2">Timeline</span></span>
          </h2>
        </div>
        
        <div class="relative max-w-3xl mx-auto">
          <div class="absolute left-4 md:left-8 top-0 bottom-0 w-px bg-gradient-to-b from-neon-rose/40 via-neon-violet/30 to-transparent"></div>
          
          {experience.map((exp, i) => (
            <div class={`reveal reveal-delay-${i + 1} relative pl-12 md:pl-20 pb-12 last:pb-0`}>
              <div class="absolute left-[11px] md:left-[27px] top-1 w-3 h-3 rounded-full bg-neon-rose shadow-neon-sm border-2 border-base"></div>
              <div class="card-neon group">
                <div class="flex items-start gap-3 mb-2">
                  <div class="flex-1">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
                      <h3
                        class="text-lg font-heading font-semibold text-text-bright"
                        data-en={exp.data.role}
                        data-zh={exp.data.roleZh || exp.data.role}
                      >{exp.data.role}</h3>
                      <span
                        class="text-xs text-muted font-mono"
                        data-en={`${exp.data.startDate} — ${exp.data.endDate}`}
                        data-zh={exp.data.dateZh ?? `${exp.data.startDate} — ${exp.data.endDate}`}
                      >{exp.data.startDate} — {exp.data.endDate}</span>
                    </div>
                    <p
                      class="text-sm text-neon-rose/70"
                      data-en={`${exp.data.company} · ${exp.data.location}`}
                      data-zh={`${exp.data.companyZh || exp.data.company} · ${exp.data.locationZh || exp.data.location}`}
                    >{exp.data.company} &middot; {exp.data.location}</p>
                  </div>
                </div>
                {(exp.body || '').split('\n').filter(line => line.trim().startsWith('-')).map((line, i) => (
                  <p
                    class="text-sm text-muted leading-relaxed mt-2 pl-3 border-l border-white/5"
                    data-en={line.trim().slice(2)}
                    data-zh={(exp.data.bulletsZh || [])[i] || line.trim().slice(2)}
                  >
                    {line.trim().slice(2)}
                  </p>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="divider-neon-animated"></div>

    <!-- Education -->
    <section class="py-20 md:py-28">
      <div class="section-container">
        <div class="reveal text-center mb-14">
          <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">
            <span class="text-gradient-rose" data-i18n="section.edu.title">Education</span>
          </h2>
        </div>
        
        <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
          <div class="reveal reveal-delay-1 card-neon group">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-neon-violet/10 border border-neon-violet/20 flex items-center justify-center flex-shrink-0">
                <BrandLogo brand="nyu" size="md" />
              </div>
              <div>
                <h3 class="font-heading font-semibold text-text-bright" data-i18n="edu.nyu.name">New York University</h3>
                <p class="text-sm text-neon-rose/70" data-i18n="edu.nyu.inst">Courant Institute of Mathematical Sciences</p>
                <p class="text-sm text-muted mt-1" data-i18n="edu.nyu.degree">M.S. Computer Science (AI Concentration)</p>
                <div class="flex items-center gap-3 mt-2 text-xs text-muted">
                  <span>Sep 2025 – May 2027</span>
                  <span class="text-neon-rose">GSAS / CAS</span>
                </div>
              </div>
            </div>
          </div>
          
          <div class="reveal reveal-delay-2 card-neon group">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-neon-violet/10 border border-neon-violet/20 flex items-center justify-center flex-shrink-0">
                <BrandLogo brand="nyu" size="md" />
              </div>
              <div>
                <h3 class="font-heading font-semibold text-text-bright" data-i18n="edu.bs.name">New York University</h3>
                <p class="text-sm text-muted mt-1" data-i18n="edu.bs.degree">B.S. Computer Science</p>
                <div class="flex items-center gap-3 mt-2 text-xs text-muted">
                  <span>Sep 2021 – May 2025</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 md:py-28">
      <div class="section-container text-center">
        <div class="reveal card-neon max-w-2xl mx-auto py-12 px-8">
          <h2 class="text-2xl md:text-3xl font-heading font-bold mb-4">
            <span data-i18n="section.cta.t1">Let's</span>
            <span class="text-gradient-rose"> <span data-i18n="section.cta.t2">Collaborate</span></span>
          </h2>
          <p class="text-muted mb-8 max-w-md mx-auto" data-i18n="section.cta.desc">
            Interested in AI systems, GPU computing, distributed systems, or full-stack engineering? I'd love to connect.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="btn-neon-fill" data-i18n="section.cta.contact">Get in Touch</a>
            <a href="https://github.com/Michaelliu1017" target="_blank" rel="noopener noreferrer" class="btn-neon">
              <svg class="inline-block w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              <span data-i18n="section.cta.github">View GitHub</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
