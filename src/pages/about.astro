---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import BrandLogo from '../components/BrandLogo.astro';
import { getCollection } from 'astro:content';

const allExperience = await getCollection('experience');
const experience = allExperience.sort((a, b) => a.data.order - b.data.order);

const skills = [
  { category: 'Languages',     i18nKey: 'skill.languages', items: ['Java', 'Python', 'C/C++', 'SQL', 'Golang', 'JavaScript/TypeScript', 'HTML/CSS', 'Racket'] },
  { category: 'ML / AI',       i18nKey: 'skill.mlai',      items: ['PyTorch', 'Spring AI', 'RAG', 'OpenCV', 'DINOv2/v3', 'Ollama', 'NumPy', 'scikit-learn', 'nomic-embed-text'] },
  { category: 'Systems & HPC', i18nKey: 'skill.systems',   items: ['CUDA', 'POSIX Threads', 'MPI', 'CSR Sparse Matrix', 'Memory Optimization', 'GPU Kernels'] },
  { category: 'Frameworks',    i18nKey: 'skill.frameworks', items: ['Spring Boot', 'Flask', 'React', 'Node.js', 'Express', 'REST APIs', 'WebSocket'] },
  { category: 'Data & Storage',i18nKey: 'skill.data',      items: ['PostgreSQL', 'MongoDB', 'MySQL', 'Redis', 'pgvector', 'Milvus', 'PyMongo'] },
  { category: 'DevOps & Cloud',i18nKey: 'skill.devops',    items: ['Docker', 'Kubernetes', 'AWS', 'GitLab CI', 'GitHub Actions', 'Docker Compose'] },
];

const coursework = [
  { area: 'AI & ML',  i18nKey: 'about.course.mlai',    courses: ['Deep Learning', 'Reinforcement Learning', 'Computer Vision', 'Natural Language Processing'] },
  { area: 'Systems',  i18nKey: 'about.course.systems',  courses: ['Operating Systems', 'Distributed Systems', 'High-Performance Computing', 'Concurrent Programming'] },
  { area: 'Theory',   i18nKey: 'about.course.theory',   courses: ['Algorithms & Data Structures', 'Programming Languages', 'Linear Algebra', 'Probability & Statistics'] },
];
---

<Layout title="About — Guoliang Liu" description="CS Graduate Student at NYU Courant building AI/ML systems and systems software.">
  <Navigation />
  
  <main id="main-content" class="py-20 md:py-28">
    <!-- Hero -->
    <section class="section-container mb-20">
      <div class="max-w-4xl flex flex-col md:flex-row md:items-center md:gap-12">
        <div class="flex-shrink-0 mb-8 md:mb-0 md:order-2">
          <div class="w-48 h-48 md:w-56 md:h-56 rounded-2xl border-2 border-neon-rose/30 shadow-[0_0_25px_rgba(232,98,26,0.18)] mx-auto bg-surface flex items-center justify-center overflow-hidden">
            <span class="text-6xl md:text-7xl font-heading font-bold text-gradient-neon select-none">GL</span>
          </div>
        </div>
        <div class="flex-1">
          <p class="text-neon-rose font-mono text-sm tracking-widest uppercase mb-4 animate-fade-in" data-i18n="about.eyebrow">About Me</p>
          <h1 class="text-4xl md:text-5xl font-heading font-bold mb-6">
            <span class="text-gradient-neon" data-i18n="about.t1">Software Engineer</span>
            <br />
            <span class="text-text-bright" data-i18n="about.t2">&amp; CS Graduate</span>
          </h1>
          <p class="text-lg text-muted-light leading-relaxed mb-4" data-i18n="about.p1">
            M.S. Computer Science student at NYU Courant (AI concentration) with hands-on experience building AI/ML systems, GPU-accelerated computing, and full-stack applications. Passionate about the intersection of theoretical rigor and practical systems engineering.
          </p>
          <p class="text-lg text-muted-light leading-relaxed" data-i18n="about.p2">
            Previously worked as a software engineering intern building LLM-powered applications with Java + Spring Boot, and developing server infrastructure and robotics control systems.
          </p>
          <div class="flex flex-wrap gap-3 mt-6">
            <a href="mailto:gl2362@nyu.edu" class="btn-neon text-sm">
              <svg class="inline-block w-4 h-4 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
              gl2362@nyu.edu
            </a>
            <a href="https://github.com/Michaelliu1017" target="_blank" rel="noopener noreferrer" class="btn-neon-fill text-sm">
              <svg class="inline-block w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              <span data-i18n="about.btn.github">GitHub</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <div class="divider-neon-animated"></div>

    <!-- Experience -->
    <section class="section-container py-20 md:py-28">
      <div class="reveal text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">
          <span data-i18n="about.exp.t1">Professional</span>
          <span class="text-gradient-rose"> <span data-i18n="about.exp.t2">Experience</span></span>
        </h2>
      </div>
      
      <div class="relative max-w-3xl mx-auto">
        <div class="absolute left-4 md:left-8 top-0 bottom-0 w-px bg-gradient-to-b from-neon-rose/40 via-neon-violet/30 to-transparent"></div>
        
        {experience.map((exp, i) => (
          <div class={`reveal reveal-delay-${i + 1} relative pl-12 md:pl-20 pb-12 last:pb-0`}>
            <div class="absolute left-[11px] md:left-[27px] top-1 w-3 h-3 rounded-full bg-neon-rose shadow-neon-sm border-2 border-base"></div>
            <div class="card-neon group">
              <div class="flex items-start gap-3 mb-2">
                <div class="flex-1">
                  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
                    <h3
                      class="text-lg font-heading font-semibold text-text-bright"
                      data-en={exp.data.role}
                      data-zh={exp.data.roleZh || exp.data.role}
                    >{exp.data.role}</h3>
                    <span class="text-xs text-muted font-mono">{exp.data.startDate} — {exp.data.endDate}</span>
                  </div>
                  <p
                    class="text-sm text-neon-rose/70"
                    data-en={`${exp.data.company} · ${exp.data.location}`}
                    data-zh={`${exp.data.companyZh || exp.data.company} · ${exp.data.locationZh || exp.data.location}`}
                  >{exp.data.company} &middot; {exp.data.location}</p>
                </div>
              </div>
              <div class="space-y-2">
                {(exp.body || '').split('\n').filter(line => line.trim().startsWith('-')).map((line, i) => (
                  <p
                    class="text-sm text-muted leading-relaxed pl-3 border-l border-white/5"
                    data-en={line.trim().slice(2)}
                    data-zh={(exp.data.bulletsZh || [])[i] || line.trim().slice(2)}
                  >
                    {line.trim().slice(2)}
                  </p>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="divider-neon-animated"></div>

    <!-- Skills Matrix -->
    <section class="section-container py-20 md:py-28">
      <div class="reveal text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">
          <span data-i18n="about.skills.t1">Skills</span>
          <span class="text-gradient-rose"> <span data-i18n="about.skills.t2">Matrix</span></span>
        </h2>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {skills.map((group, i) => (
          <div class={`reveal reveal-delay-${(i % 5) + 1} card-neon`}>
            <h3 data-i18n={group.i18nKey} class="text-sm font-heading font-semibold uppercase tracking-wider mb-3 text-neon-rose">
              {group.category}
            </h3>
            <div class="flex flex-wrap gap-2">
              {group.items.map(item => (
                <span class="text-xs px-2.5 py-1 rounded-full border bg-neon-rose/5 text-neon-rose/80 border-neon-rose/15">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="divider-neon-animated"></div>

    <!-- Relevant Coursework -->
    <section class="section-container py-20 md:py-28">
      <div class="reveal text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">
          <span data-i18n="about.course.t1">Relevant</span>
          <span class="text-gradient-rose"> <span data-i18n="about.course.t2">Coursework</span></span>
        </h2>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {coursework.map((group, i) => (
          <div class={`reveal reveal-delay-${i + 1} card-neon`}>
            <h3 data-i18n={group.i18nKey} class="text-sm font-heading font-semibold uppercase tracking-wider mb-3 text-neon-gold">
              {group.area}
            </h3>
            <ul class="space-y-2">
              {group.courses.map(course => (
                <li class="text-sm text-muted flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-neon-rose/50 flex-shrink-0"></span>
                  {course}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <div class="divider-neon-animated"></div>

    <!-- Education -->
    <section class="section-container py-20 md:py-28">
      <div class="reveal text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">
          <span class="text-gradient-rose" data-i18n="about.edu.title">Education</span>
        </h2>
      </div>
      
      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <div class="reveal reveal-delay-1 card-neon group">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-lg bg-neon-violet/10 border border-neon-violet/20 flex items-center justify-center flex-shrink-0">
              <BrandLogo brand="nyu" size="md" />
            </div>
            <div>
              <h3 class="font-heading font-semibold text-text-bright" data-i18n="edu.nyu.name">New York University</h3>
              <p class="text-sm text-neon-rose/70" data-i18n="edu.nyu.inst">Courant Institute of Mathematical Sciences</p>
              <p class="text-sm text-muted mt-1" data-i18n="edu.nyu.degree">M.S. Computer Science (AI Concentration)</p>
              <div class="flex items-center gap-3 mt-2 text-xs text-muted">
                <span>Sep 2025 – May 2027</span>
                <span class="text-neon-rose">GSAS / CAS</span>
              </div>
            </div>
          </div>
        </div>
        
        <div class="reveal reveal-delay-2 card-neon group">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-lg bg-neon-violet/10 border border-neon-violet/20 flex items-center justify-center flex-shrink-0">
              <BrandLogo brand="nyu" size="md" />
            </div>
            <div>
              <h3 class="font-heading font-semibold text-text-bright" data-i18n="edu.bs.name">New York University</h3>
              <p class="text-sm text-muted mt-1" data-i18n="edu.bs.degree">B.S. Computer Science</p>
              <div class="flex items-center gap-3 mt-2 text-xs text-muted">
                <span>Sep 2021 – May 2025</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
