---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { name: 'Home',     href: '/',         i18n: 'nav.home'     },
  { name: 'About',    href: '/about',    i18n: 'nav.about'    },
  { name: 'Projects', href: '/projects', i18n: 'nav.projects' },
  { name: 'Contact',  href: '/contact',  i18n: 'nav.contact'  },
];
---

<footer class="relative mt-20">
  <div class="divider-neon-animated"></div>
  
  <div class="section-container py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="text-2xl font-heading font-bold text-gradient-rose">
          GL<span class="text-neon-rose">.</span>
        </a>
        <p class="mt-3 text-sm text-muted max-w-xs" data-i18n="footer.desc">
          CS Graduate Student at NYU Courant building AI/ML systems, systems software, and full-stack applications.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-heading font-semibold text-text uppercase tracking-wider mb-4" data-i18n="footer.nav">Navigation</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} data-i18n={link.i18n}
                 class="text-sm text-muted hover:text-neon-rose transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h3 class="text-sm font-heading font-semibold text-text uppercase tracking-wider mb-4" data-i18n="footer.connect">Connect</h3>
        <ul class="space-y-2">
          <li>
            <a href="https://github.com/Michaelliu1017" target="_blank" rel="noopener noreferrer"
               class="text-sm text-muted hover:text-neon-rose transition-colors inline-flex items-center gap-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
          </li>
          <li>
            <a href="mailto:gl2362@nyu.edu"
               class="text-sm text-muted hover:text-neon-rose transition-colors inline-flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
              gl2362@nyu.edu
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="divider-neon mt-8 mb-6"></div>

    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-muted">
      <p>
        &copy; {currentYear} <span data-i18n="name.full">Guoliang Liu</span>.
        <span data-i18n="footer.rights">All rights reserved.</span>
      </p>
      <p class="flex items-center gap-1">
        <span data-i18n="footer.built">Built with</span>
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer"
           class="text-neon-violet hover:text-neon-rose transition-colors font-medium">Astro</a>
        &
        <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer"
           class="text-neon-violet hover:text-neon-rose transition-colors font-medium">Tailwind</a>
      </p>
    </div>
  </div>
</footer>
