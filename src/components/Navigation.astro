---
import digitOwl from '../assets/digitowl.png';

const navItems = [
  { name: 'Home',     href: '/',        i18n: 'nav.home'     },
  { name: 'About',    href: '/about',   i18n: 'nav.about'    },
  { name: 'Projects', href: '/projects',i18n: 'nav.projects' },
  { name: 'Contact',  href: '/contact', i18n: 'nav.contact'  },
];

const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-base/80 backdrop-blur-xl border-b border-white/5" id="main-nav">
  <div class="section-container">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center hover:opacity-80 transition-opacity rounded-lg bg-black p-1">
        <img src={digitOwl.src} alt="Logo" width={digitOwl.width} height={digitOwl.height} class="h-8 w-8 object-contain" />
      </a>
      
      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            data-i18n={item.i18n}
            class={`relative py-1 text-sm font-medium tracking-wide transition-colors duration-200 ${
              currentPath === item.href
                ? 'text-neon-rose'
                : 'text-muted-light hover:text-text'
            }`}
          >
            {item.name}
            {currentPath === item.href && (
              <span class="absolute -bottom-[1px] left-0 w-full h-px bg-neon-rose shadow-neon-sm" />
            )}
          </a>
        ))}
      </div>

      <!-- Right controls: GitHub + Lang Toggle -->
      <div class="hidden md:flex items-center gap-3">
        <a href="https://github.com/Michaelliu1017" target="_blank" rel="noopener noreferrer"
           class="text-muted hover:text-neon-rose transition-colors" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>

        <!-- Language toggle button -->
        <button
          data-lang-toggle
          class="flex items-center gap-1.5 text-xs font-mono px-3 py-1.5 rounded-full border border-white/10 hover:border-neon-rose/40 transition-all duration-200 select-none cursor-pointer"
          aria-label="Toggle language"
        >
          <span class="lang-active-en text-neon-rose font-semibold">EN</span>
          <span class="text-white/25">/</span>
          <span class="lang-active-zh text-muted">中文</span>
        </button>
      </div>
      
      <!-- Mobile: Lang toggle + Hamburger -->
      <div class="md:hidden flex items-center gap-2">
        <button
          data-lang-toggle
          class="flex items-center gap-1 text-[11px] font-mono px-2.5 py-1 rounded-full border border-white/10 hover:border-neon-rose/40 transition-all duration-200 select-none cursor-pointer"
          aria-label="Toggle language"
        >
          <span class="lang-active-en text-neon-rose font-semibold">EN</span>
          <span class="text-white/25">/</span>
          <span class="lang-active-zh text-muted">中文</span>
        </button>

        <button
          class="text-muted-light hover:text-neon-rose transition-colors p-2"
          id="mobile-menu-btn"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6 hamburger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-6 h-6 close-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="md:hidden hidden" id="mobile-menu">
    <div class="px-4 py-6 space-y-1 bg-base/95 backdrop-blur-xl border-t border-white/5">
      {navItems.map((item) => (
        <a
          href={item.href}
          data-i18n={item.i18n}
          class={`block px-4 py-3 rounded-lg text-sm font-medium tracking-wide transition-all duration-200 ${
            currentPath === item.href
              ? 'text-neon-rose bg-neon-rose/5'
              : 'text-muted-light hover:text-text hover:bg-white/5'
          }`}
        >
          {item.name}
        </a>
      ))}
      <div class="divider-neon my-4"></div>
      <div class="flex items-center space-x-4 px-4 py-2">
        <a href="https://github.com/Michaelliu1017" target="_blank" rel="noopener noreferrer"
           class="text-muted hover:text-neon-rose transition-colors" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = btn?.querySelector('.hamburger-icon');
  const closeIcon = btn?.querySelector('.close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  document.addEventListener('astro:after-swap', () => {
    menu?.classList.add('hidden');
    hamburger?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
  });
</script>
